# =============================================================================
# Agentic AI SOC Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.
# All variables are prefixed with SOC_ in the app (pydantic-settings).
# =============================================================================

# --- Redis ---
SOC_REDIS_URL=redis://redis:6379/0

# --- MongoDB ---
SOC_MONGO_URL=mongodb://mongodb:27017
SOC_MONGO_DB_NAME=soc_platform

# --- Ingestion Auth ---
SOC_INGESTION_AUTH_TOKEN=soc-ingest-token-dev

# --- Groq LLM (Phase 5) ---
# 8B has far higher free-tier limits than 70B; swap to llama-3.3-70b-versatile
# for stronger reasoning if your Groq tier allows it.
SOC_GROQ_MODEL=llama-3.1-8b-instant
SOC_GROQ_API_KEY=

# --- AlienVault OTX (Phase 3) ---
SOC_OTX_API_KEY=

# --- Slack (Phase 6) ---
SOC_SLACK_WEBHOOK_URL=
